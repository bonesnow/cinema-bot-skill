# ==============================================================================
# Cinema Bot 配置文件
# 使用方法：cp .env.example .env，然后只修改带“需要你填写”的项目。
# .env、data/、Cookie、资源站配置和扫码登录态都不要提交到 GitHub。
# ==============================================================================

# ----------------------------------------------------------------------------
# 0. 运行模式
# ----------------------------------------------------------------------------
# 首次部署保持 true：只检索和评分，不真正转存。
DRY_RUN=true
# true：找到资源后自动转存；false：只回复资源信息。
AUTO_SAVE=true

# ----------------------------------------------------------------------------
# 1. 夸克网盘（扫码登录，无需填写 Cookie）
# ----------------------------------------------------------------------------
# 保持为空。服务启动后，在飞书发送“夸克登录”扫码获取登录态。
QUARK_COOKIE=
# 登录态持久化文件，不建议修改。
QUARK_AUTH_FILE=/data/quark_auth.json
# 二维码有效时间，范围 60-600 秒。
QUARK_QR_TIMEOUT=300
# 🟡【可选】转存目标文件夹 FID；0 表示网盘根目录。
QUARK_TARGET_FID=0
# 🟡【可选】直接转存带提取码分享时使用的默认提取码。
QUARK_DEFAULT_PASSCODE=

# ----------------------------------------------------------------------------
# 1.1 媒体库自动整理与分类刮削
# ----------------------------------------------------------------------------
# 转存完成后自动创建 Plex / Jellyfin / Infuse 兼容目录并移动文件。
ORGANIZE_AFTER_SAVE=true
# 自动创建的媒体库根目录名称。
LIBRARY_ROOT_NAME=夸克影视
# 🟡【可选】已有媒体库目录的 FID；留空时在网盘根目录自动创建 LIBRARY_ROOT_NAME。
LIBRARY_ROOT_FID=
# true：按 电影/电视剧 和 NAStool 风格二级分类建立目录。
LIBRARY_GENRE_FOLDERS=true
# true：已经包含 2160p、REMUX、HDR 等规范标签的文件保留原文件名。
LIBRARY_KEEP_SCENE_NAMES=true
# 🟡【可选但推荐】OMDb API Key。留空仍能整理，会使用标题和来源信息做基础分类。
OMDB_API_KEY=
# 元数据缓存文件，不建议修改。
METADATA_CACHE_PATH=/data/metadata_cache.json

# ----------------------------------------------------------------------------
# 2. 资源源（至少配置一种；公开仓库不内置你的私有资源站配置）
# ----------------------------------------------------------------------------
# 方案 A：你自己维护或有权使用的资源 API。
# 需要你填写。多个地址用英文分号 ; 分隔。
# 示例：https://media.example.com/api/search
PROVIDER_API_URLS=
# 🟡【按需填写】API Bearer Token；API 不鉴权则留空。
PROVIDER_API_TOKEN=

# 方案 B：本地合法资源目录。若使用方案 A，可把本项留空。
# 使用本地目录时，复制 catalog.example.json 到 data/catalog.json。
LOCAL_CATALOG_PATH=

# ----------------------------------------------------------------------------
# 3. 飞书机器人（当前主渠道；使用飞书时前三项必填）
# ----------------------------------------------------------------------------
# 🔴【需要你填写-飞书】开放平台应用凭证 → App ID
FEISHU_APP_ID=__FILL_FEISHU_APP_ID__
# 🔴【需要你填写-飞书】开放平台应用凭证 → App Secret
FEISHU_APP_SECRET=__FILL_FEISHU_APP_SECRET__
# 🔴【需要你填写-飞书】事件订阅 → Verification Token
FEISHU_VERIFICATION_TOKEN=__FILL_FEISHU_VERIFICATION_TOKEN__
# 🔴【生产环境强烈建议填写】允许使用机器人的 open_id，多个用英文逗号分隔。
# 获取方式见《配置填写清单.md》。测试阶段可暂时留空。
FEISHU_ALLOWED_OPEN_IDS=

# ----------------------------------------------------------------------------
# 4. 企业微信（可选；不用企业微信就全部留空）
# ----------------------------------------------------------------------------
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=0
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_ALLOWED_USER_IDS=

# ----------------------------------------------------------------------------
# 5. 反向代理说明（不由应用读取，仅作为部署记录）
# ----------------------------------------------------------------------------
# 🔴【需要你准备】公网 HTTPS 域名，例如 bot.example.com
# 飞书事件回调：https://你的域名/webhooks/feishu
# 企业微信回调：https://你的域名/webhooks/wecom
PUBLIC_HOST=
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=

# 可选站点适配器：只在你有权访问并允许自动化检索时启用。
# 公开仓库只保留变量名，不保存你的资源站地址、Cookie 或登录态。
PANHUB_BASE_URL=
PANHUB_COOKIE=
PANHUB_CONCURRENCY=4
PANHUB_TIMEOUT=30

JPMOM_ENABLED=false
JPMOM_BASE_URL=
JPMOM_COOKIE=
JPMOM_TIMEOUT=30

HOUTUPAN_ENABLED=false
HOUTUPAN_BASE_URL=
HOUTUPAN_COOKIE=
HOUTUPAN_TIMEOUT=30

# 自定义网站配置文件只放在 data/websites.yaml，不提交到 Git。
WEBSITE_CONFIG_PATH=
WEBSITE_ALLOW_PRIVATE_HOSTS=false
